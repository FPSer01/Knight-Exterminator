  speeches:
  - "\u041A\u0443\u0440\u0438\u043D\u044B\u0439 \u0441\u043E\u043A \u0433\u0434\u0435-\u0442\u043E
    \u0440\u044F\u0434\u043E\u043C..."
  - 8|
  - "\u042D\u0442\u043E \u0442\u0438\u043F \u043C\u0435\u043D\u044F \u043F\u0443\u0433\u0430\u0435\u0442..."
  - "\u042F \u0442\u0443\u0442 \u043F\u043B\u0435\u043D\u043D\u0438\u043A..."
  - "\u0422\u044B \u043A\u0442\u043E? \u041D\u0435 \u043C\u0435\u0448\u0430\u0439
    \u043C\u043D\u0435!"
  - "\u0412\u044B\u0445\u043E\u0434 \u0432 \u0441\u043E\u0441\u0435\u0434\u043D\u0435\u0439
    \u043A\u043E\u043C\u043D\u0430\u0442\u0435..."
  - "\u041D\u0430 \u043A\u043E\u0433\u043E \u044F \u043F\u043E\u0445\u043E\u0436?"
  - "\u042F \u043D\u0435 \u0434\u0430\u043C \u0441\u0432\u043E\u0438 \u0441\u043E\u043A\u0440\u043E\u0432\u0438\u0449\u0430!"
  - 1 + 1 = 3?
  - "\u0414\u0430\u0439 \u043C\u043D\u0435 \u0442\u0432\u043E\u0439 \u043C\u0435\u0447!"
  - "\u0414\u0430\u0436\u0435 \u043D\u0435 \u043F\u044B\u0442\u0430\u0439\u0441\u044F..."
  - <--
  - -->
  - "\u0422\u044B \u0432\u0438\u0434\u0435\u043B \u0447\u0442\u043E \u0431\u0443\u0434\u0435\u0442
