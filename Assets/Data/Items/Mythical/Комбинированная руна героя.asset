    \u0437\u0430\u0449\u0438\u0442\u0443 \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0430.
    \u0423\u0432\u0435\u043B\u0438\u0447\u0438\u0432\u0430\u0435\u0442 <style=\"Highlight\">\u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435</style>
    \u043D\u0430 <style=\"Buff\">10 \u0435\u0434\u0438\u043D\u0438\u0446</style>,
    <style=\"Highlight\">\u0432\u044B\u043D\u043E\u0441\u043B\u0438\u0432\u043E\u0441\u0442\u044C</style>
    \u043D\u0430 <style=\"Buff\">10 \u0435\u0434\u0438\u043D\u0438\u0446</style>,
    <style=\"Highlight\">\u0437\u0430\u0449\u0438\u0442\u0443</style> \u043D\u0430
    <style=\"Buff\">5 \u0435\u0434\u0438\u043D\u0438\u0446</style>."
